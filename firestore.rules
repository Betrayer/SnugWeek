rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function owner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function validTask(d) {
      return d.keys().hasOnly([
          'title', 'status', 'bucket', 'weekId', 'day', 'listId',
          'order', 'createdAt', 'updatedAt', 'completedAt', 'carriedFrom',
          'tagIds', 'subtaskCount', 'subtaskDone', 'time', 'remindOffsetMin',
          'routineId', 'attachmentCount'
        ])
        && d.title is string && d.title.size() >= 1 && d.title.size() <= 500
        && (d.status == 'open' || d.status == 'done')
        && d.order is number
        && d.createdAt is number
        && d.updatedAt is number
        && (d.completedAt == null || d.completedAt is number)
        && (d.carriedFrom == null || d.carriedFrom is string)
        && (!('tagIds' in d) || (d.tagIds is list && d.tagIds.size() <= 20))
        && (!('subtaskCount' in d)
          || (d.subtaskCount is number && d.subtaskCount >= 0 && d.subtaskCount <= 200))
        && (!('subtaskDone' in d)
          || (d.subtaskDone is number && d.subtaskDone >= 0 && d.subtaskDone <= 200))
        && (!('time' in d) || d.time == null
          || (d.time is string && d.time.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$')))
        && (!('remindOffsetMin' in d) || d.remindOffsetMin == null
          || (d.remindOffsetMin is number && d.remindOffsetMin >= 0))
        && (d.bucket != 'list'
          || !('remindOffsetMin' in d) || d.remindOffsetMin == null)
        && (!('routineId' in d) || d.routineId == null || d.routineId is string)
        && (!('attachmentCount' in d)
          || (d.attachmentCount is number && d.attachmentCount >= 0
            && d.attachmentCount <= 200))
        && (
          (d.bucket == 'day'
            && d.weekId is string
            && d.day is number && d.day >= 1 && d.day <= 7
            && d.listId == null)
          || (d.bucket == 'list'
            && d.listId is string
            && d.weekId == null
            && d.day == null)
        );
    }

    function validSubtask(d) {
      return d.keys().hasOnly(['title', 'done', 'order', 'createdAt'])
        && d.title is string && d.title.size() >= 1 && d.title.size() <= 200
        && d.done is bool
        && d.order is number
        && d.createdAt is number;
    }

    function validTag(d) {
      return d.keys().hasOnly(['name', 'color', 'order', 'createdAt'])
        && d.name is string && d.name.size() >= 1 && d.name.size() <= 40
        && d.color in ['rose', 'coral', 'amber', 'olive', 'fern',
          'teal', 'azure', 'violet', 'plum', 'mocha']
        && d.order is number
        && d.createdAt is number;
    }

    function validRoutine(d) {
      return d.keys().hasOnly([
          'title', 'freq', 'days', 'time', 'remindOffsetMin', 'active', 'createdAt'
        ])
        && d.title is string && d.title.size() >= 1 && d.title.size() <= 200
        && (d.freq == 'daily' || d.freq == 'weekly')
        && d.days is list && d.days.size() <= 7 && d.days.hasOnly([1, 2, 3, 4, 5, 6, 7])
        && (d.time == null
          || (d.time is string && d.time.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$')))
        && (d.remindOffsetMin == null
          || (d.remindOffsetMin is number && d.remindOffsetMin >= 0))
        && d.active is bool
        && d.createdAt is number;
    }

    function validRoutineRun(d) {
      return d.keys().hasOnly(['routineIds', 'updatedAt'])
        && d.routineIds is list && d.routineIds.size() <= 500
        && d.updatedAt is number;
    }

    function validList(d) {
      return d.keys().hasOnly([
          'kind', 'name', 'order', 'createdAt', 'day', 'attachmentCount'
        ])
        && (d.kind == 'tasks' || d.kind == 'ideas' || d.kind == 'custom')
        && (d.name == null || d.name is string)
        && d.order is number
        && d.createdAt is number
        && (!('day' in d) || d.day == null || d.day is number)
        && (!('attachmentCount' in d)
          || (d.attachmentCount is number && d.attachmentCount >= 0
            && d.attachmentCount <= 200));
    }

    function validAttachment(d) {
      return d.keys().hasOnly([
          'targetType', 'taskId', 'listId', 'weekId', 'day', 'kind',
          'order', 'createdAt', 'storagePath', 'url', 'name', 'mime',
          'size', 'thumbPath', 'thumbUrl', 'width', 'height', 'durationMs',
          'href', 'title', 'previewImage'
        ])
        && d.targetType in ['task', 'list', 'day']
        && d.kind in ['image', 'audio', 'video', 'file', 'link']
        && d.order is number
        && d.createdAt is number
        && (d.taskId == null || d.taskId is string)
        && (d.listId == null || d.listId is string)
        && (d.weekId == null || d.weekId is string)
        && (d.day == null || (d.day is number && d.day >= 1 && d.day <= 7))
        && (d.storagePath == null || d.storagePath is string)
        && (d.url == null || d.url is string)
        && (d.name == null || (d.name is string && d.name.size() <= 512))
        && (d.mime == null || d.mime is string)
        && (d.size == null || (d.size is number && d.size >= 0))
        && (d.thumbPath == null || d.thumbPath is string)
        && (d.thumbUrl == null || d.thumbUrl is string)
        && (d.width == null || d.width is number)
        && (d.height == null || d.height is number)
        && (d.durationMs == null || d.durationMs is number)
        && (d.href == null || (d.href is string && d.href.size() <= 2048))
        && (d.title == null || (d.title is string && d.title.size() <= 512))
        && (d.previewImage == null || d.previewImage is string)
        && (
          (d.targetType == 'task' && d.taskId is string)
          || (d.targetType == 'list' && d.listId is string)
          || (d.targetType == 'day' && d.weekId is string && d.day is number)
        );
    }

    function validWeek(d) {
      return d.keys().hasOnly([
          'note', 'dayNotes', 'daysOff', 'trackerValues', 'habitChecks',
          'decorations', 'updatedAt'
        ])
        && (!('note' in d) || d.note is string)
        && (!('dayNotes' in d) || d.dayNotes is map)
        && (!('daysOff' in d) || d.daysOff == null || d.daysOff is list)
        && (!('trackerValues' in d) || d.trackerValues is map)
        && (!('habitChecks' in d) || d.habitChecks is map)
        && (!('decorations' in d) || d.decorations == null
          || (d.decorations is list && d.decorations.size() <= 120))
        && (!('updatedAt' in d) || d.updatedAt is number);
    }

    function validTracker(d) {
      return d.keys().hasOnly(['name', 'type', 'icon', 'order', 'enabled', 'createdAt'])
        && d.name is string
        && (d.type == 'scale5' || d.type == 'emoji' || d.type == 'number' || d.type == 'checkbox')
        && d.icon is string
        && d.order is number
        && d.enabled is bool
        && d.createdAt is number;
    }

    function validHabit(d) {
      return d.keys().hasOnly(['name', 'icon', 'order', 'archived', 'createdAt'])
        && d.name is string
        && (d.icon == null || d.icon is string)
        && d.order is number
        && d.archived is bool
        && d.createdAt is number;
    }

    function validStats(d) {
      return d.keys().hasOnly(['tasksCompleted', 'perDay', 'updatedAt'])
        && d.tasksCompleted is number
        && d.perDay is map
        && (!('updatedAt' in d) || d.updatedAt is number);
    }

    match /users/{uid} {
      allow read, write: if owner(uid);

      match /tasks/{taskId} {
        allow read, delete: if owner(uid);
        allow create, update: if owner(uid) && validTask(request.resource.data);

        match /items/{itemId} {
          allow read, delete: if owner(uid);
          allow create, update: if owner(uid) && validSubtask(request.resource.data);
        }
      }

      match /attachments/{attachmentId} {
        allow read, delete: if owner(uid);
        allow create, update: if owner(uid)
          && validAttachment(request.resource.data);
      }

      match /tags/{tagId} {
        allow read, delete: if owner(uid);
        allow create, update: if owner(uid) && validTag(request.resource.data);
      }

      match /routines/{routineId} {
        allow read, delete: if owner(uid);
        allow create, update: if owner(uid) && validRoutine(request.resource.data);
      }

      match /routineRuns/{weekId} {
        allow read, delete: if owner(uid);
        allow create, update: if owner(uid) && validRoutineRun(request.resource.data);
      }

      match /lists/{listId} {
        allow read, delete: if owner(uid);
        allow create, update: if owner(uid) && validList(request.resource.data);
      }

      match /weeks/{weekId} {
        allow read, delete: if owner(uid);
        allow create, update: if owner(uid) && validWeek(request.resource.data);
      }

      match /trackers/{trackerId} {
        allow read, delete: if owner(uid);
        allow create, update: if owner(uid) && validTracker(request.resource.data);
      }

      match /habits/{habitId} {
        allow read, delete: if owner(uid);
        allow create, update: if owner(uid) && validHabit(request.resource.data);
      }

      match /stats/{monthId} {
        allow read, delete: if owner(uid);
        allow create, update: if owner(uid) && validStats(request.resource.data);
      }

      match /migrations/{anonUid} {
        allow read, write: if owner(uid);
      }
    }
  }
}
